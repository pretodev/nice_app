{
  "permissions": {
    "allow": [
      "Bash(dart format:*)",
      "Bash(dart analyze:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "mcp__dart__hot_reload",
      "mcp__dart__get_runtime_errors",
      "mcp__dart__get_app_logs",
      "mcp__dart__get_active_location",
      "mcp__dart__list_running_apps",
      "mcp__dart__list_devices",
      "mcp__dart__analyze_files",
      "mcp__dart__dart_format",
      "mcp__dart__widget_inspector"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dart-quality.sh"
          }
        ]
      }
    ]
  }
}
